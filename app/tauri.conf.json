{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "LiberShare",
	"version": "0.0.1",
	"identifier": "org.libersoft.libershare",
	"build": {
		"frontendDist": "../frontend/build"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": [],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.png",
			"icons/icon.ico"
		],
		"licenseFile": "../LICENSE",
		"windows": {
			"nsis": {
				"displayLanguageSelector": true,
				"installerIcon": "icons/icon.ico",
				"installMode": "both",
				"headerImage": "nsis-img/nsis-header.bmp",
				"sidebarImage": "nsis-img/nsis-sidebar.bmp",
				"startMenuFolder": "LiberShare",
				"installerHooks": "nsis-hooks.nsh",
				"languages": [
					"Albanian",
					"Arabic",
					"Asturian",
					"Basque",
					"Belarusian",
					"Corsican",
					"Czech",
					"Danish",
					"Dutch",
					"English",
					"Esperanto",
					"French",
					"German",
					"Hebrew",
					"Indonesian",
					"Italian",
					"Japanese",
					"Mongolian",
					"Norwegian",
					"NorwegianNynorsk",
					"Polish",
					"Portuguese",
					"PortugueseBR",
					"Russian",
					"ScotsGaelic",
					"SimpChinese",
					"Slovak",
					"Slovenian",
					"Spanish",
					"SpanishInternational",
					"Swedish",
					"Tatar",
					"TradChinese",
					"Ukrainian",
					"Vietnamese"
				],
				"customLanguageFiles": {
					"Albanian": "nsis-langs/Albanian.nsh",
					"Asturian": "nsis-langs/Asturian.nsh",
					"Basque": "nsis-langs/Basque.nsh",
					"Belarusian": "nsis-langs/Belarusian.nsh",
					"Corsican": "nsis-langs/Corsican.nsh",
					"Czech": "nsis-langs/Czech.nsh",
					"Danish": "nsis-langs/Danish.nsh",
					"Esperanto": "nsis-langs/Esperanto.nsh",
					"Hebrew": "nsis-langs/Hebrew.nsh",
					"Indonesian": "nsis-langs/Indonesian.nsh",
					"Mongolian": "nsis-langs/Mongolian.nsh",
					"NorwegianNynorsk": "nsis-langs/NorwegianNynorsk.nsh",
					"Polish": "nsis-langs/Polish.nsh",
					"ScotsGaelic": "nsis-langs/ScotsGaelic.nsh",
					"Slovak": "nsis-langs/Slovak.nsh",
					"Slovenian": "nsis-langs/Slovenian.nsh",
					"Tatar": "nsis-langs/Tatar.nsh",
					"Vietnamese": "nsis-langs/Vietnamese.nsh"
				}
			}
		}
	},
	"mainBinaryName": "LiberShare"
}
